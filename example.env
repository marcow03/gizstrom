# mlflow
MLFLOW_S3_BUCKET=mlflow
MLFLOW_ARTIFACTS_DESTINATION=s3://${MLFLOW_S3_BUCKET}
MLFLOW_BACKEND_STORE_URI=sqlite:///metadata/metadata.sqlite
MLFLOW_TRACKING_URI=http://mlflow:5001

# feast
FEAST_S3_BUCKET=feast
FEAST_REGISTRY_DESTINATION=s3://${FEAST_S3_BUCKET}/registry/registry.db

# app and pipelines
DATA_BUCKET=data

# airflow
AIRFLOW_BASE_URL=http://airflow:8080

# inference endpoint
INFERENCE_ENDPOINT_URL=http://inference-endpoint:8001/predict

# rustfs (S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=http://rustfs:9000
BUCKETS_TO_CREATE=${MLFLOW_S3_BUCKET},${FEAST_S3_BUCKET},${DATA_BUCKET}